{
  "name": "@srsholmes/vitest-react-native",
  "version": "0.1.2",
  "description": "Support for running React Native inside Vitest",
  "type": "module",
  "main": "./dist/plugin.cjs",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js",
      "require": "./dist/setup.cjs"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist"
  ],
  "author": "Simon Holmes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srsholmes/vitest-react-native.git",
    "directory": "packages/vitest-react-native"
  },
  "bugs": {
    "url": "https://github.com/srsholmes/vitest-react-native/issues"
  },
  "homepage": "https://github.com/srsholmes/vitest-react-native#readme",
  "keywords": [
    "vitest",
    "react-native",
    "testing",
    "vite",
    "test"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "vite": ">=6",
    "vitest": ">=4"
  },
  "dependencies": {
    "@react-native/polyfills": "^2.0.0",
    "esbuild": "^0.27.4",
    "flow-remove-types": "^2.257.1",
    "pirates": "^4.0.6",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
